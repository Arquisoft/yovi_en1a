{
  "name": "webapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:e2e:run": "cucumber-js --import test/e2e/support/setup.mjs --import test/e2e/steps/**/*.mjs test/e2e/features --format progress",
    "test:e2e:auth": "cucumber-js --import test/e2e/support/setup.mjs --import test/e2e/steps/**/*.mjs test/e2e/features/auth.feature --format progress",
    "test:e2e:easy": "cucumber-js --import test/e2e/support/setup.mjs --import test/e2e/steps/**/*.mjs test/e2e/features/game-easy.feature --format progress",
    "test:e2e:difficult": "cucumber-js --import test/e2e/support/setup.mjs --import test/e2e/steps/**/*.mjs test/e2e/features/game-difficult.feature --format progress",
    "test:e2e:whynot": "cucumber-js --import test/e2e/support/setup.mjs --import test/e2e/steps/**/*.mjs test/e2e/features/game-whynot.feature --format progress",
    "test:e2e:ui": "node -e \"process.env.SHOW_UI='1'; require('child_process').execSync('npm run test:e2e:run', {stdio: 'inherit'})\"",
    "test:e2e:run-all": "node -e \"const {execSync} = require('child_process'); ['chromium', 'firefox', 'webkit'].forEach(b => execSync('npm run test:e2e:run', {env: {...process.env, BROWSER: b}, stdio: 'inherit'}))\"",
    "test:e2e:ui-all": "node -e \"const {execSync} = require('child_process'); process.env.SHOW_UI='1'; ['chromium', 'firefox', 'webkit'].forEach(b => execSync('npm run test:e2e:run', {env: {...process.env, BROWSER: b}, stdio: 'inherit'}))\"",
    "test:e2e": "start-server-and-test start:e2e http://localhost:5173 test:e2e:run-all",
    "test:e2e:install-browsers": "npx playwright install --with-deps",
    "start:all": "concurrently \"npm run dev\" \"npm --prefix ../users start\"",
    "start:e2e": "concurrently \"npm run dev\" \"npm --prefix ../users start\" \"npm --prefix ../gameyapi start\" \"cargo run --manifest-path ../gamey/Cargo.toml\""
  },
  "dependencies": {
    "i18next": "^26.0.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.3",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.4.0",
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.16",
    "concurrently": "^8.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.43.0",
    "start-server-and-test": "^2.1.3",
    "ts-node": "^10.9.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.16",
    "vitest-sonar-reporter": "^3.0.0"
  }
}
